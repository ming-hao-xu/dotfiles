#!/usr/bin/env bash

set -euo pipefail

DOTBOT_DIR="dotbot"
DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"

cd "${BASEDIR}"

PROFILE="macos"

if (( $# > 0 )) && [[ "$1" != -* ]]; then
    PROFILE="$1"
    shift
fi

case "${PROFILE}" in
    "macos")
        CONFIG="macos/install.conf.yaml"
        ;;
    *)
        printf 'Unknown install profile: %s\n' "${PROFILE}" >&2
        printf 'Usage: ./install [macos] [dotbot-options...]\n' >&2
        exit 1
        ;;
esac

git submodule update --init --recursive "${DOTBOT_DIR}"

"${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "${CONFIG}" "${@}"
