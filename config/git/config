[gpg]
	format = ssh

[commit]
	gpgSign = true

[tag]
	gpgSign = true

[init]
	defaultBranch = main

[core]
	editor = nvim
	quotePath = false

[user]
	useConfigOnly = true

[merge]
	conflictStyle = zdiff3

[diff]
	colorMoved = dimmed-zebra
	colorMovedWS = allow-indentation-change

[fetch]
	prune = true

[pull]
	ff = only

[push]
	autoSetupRemote = true

[include]
	path = ~/.config/git/local
